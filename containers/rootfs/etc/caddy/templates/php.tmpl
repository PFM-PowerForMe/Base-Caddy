{
	admin off
	auto_https off
	ocsp_stapling off
	storage file_system /tmp/caddy/data
	storage_clean_interval 24h
}

:8080 {
	log {
		output stdout
		format console
	}

	root * $CR_CADDY_WORK_DIR
	file_server

	php_fastcgi unix//run/php-fpm.sock {
		dial_timeout 300s
		trusted_proxies private_ranges
		env HTTPS {http.request.header.X-Forwarded-Proto}
		env SERVER_PORT {http.request.header.X-Forwarded-Port}
		header_up X-Real-IP {http.request.header.$CR_CADDY_REAL_IP}
		header_up X-Forwarded-For {http.request.header.$CR_CADDY_REAL_IP}
	}
}

